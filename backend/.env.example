# ============================================================
# EmotionSense AI — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to version control.
# ============================================================

# --- Model Paths (relative to backend/ directory) ---
# Path to the HSEmotion ONNX emotion recognition model
MODEL_PATH=models/emotion_hsemotion_b0.onnx

# Path to the Haar cascade XML (used as fallback face detector)
CASCADE_PATH=models/haarcascade_frontalface_default.xml

# --- Camera Settings ---
# Webcam device index (0 = default system camera, 1 = secondary/USB camera)
CAMERA_INDEX=0

# Optional: Override camera with an MJPEG stream URL (e.g. IP camera)
# Leave empty to use CAMERA_INDEX instead
CAMERA_URL=

# --- Detection Settings ---
# Confidence threshold (0-100). Emotions below this show as "Emotion Uncertain"
CONFIDENCE_THRESHOLD=40.0

# Draw bounding boxes on the live video feed (true/false)
DRAW_BOUNDING_BOXES=true

# Process every Nth frame (3 = process 1 in 3 frames, reduces CPU usage)
FRAME_SKIP=3

# EMA smoothing alpha (0.0-1.0). Lower = smoother, Higher = more reactive
EMA_ALPHA=0.3

# --- Server Settings ---
HOST=127.0.0.1
PORT=8000

# --- CORS (comma-separated list of allowed frontend origins) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080,http://127.0.0.1:8081

# --- Suppress TensorFlow/oneDNN verbose output ---
TF_ENABLE_ONEDNN_OPTS=0
