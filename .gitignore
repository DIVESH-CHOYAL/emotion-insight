# ============================================================
# EmotionSense AI — .gitignore
# ============================================================

# --- Node / Frontend ---
node_modules/
dist/
dist-ssr/
.output/
.vinxi/
.tanstack/**
.nitro/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# --- Python / Backend ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.eggs/

# Backend runtime dirs (auto-created on startup)
backend/logs/
backend/uploads/

# --- Environment (NEVER commit secrets) ---
backend/.env
.env
.env.local
.env.*.local

# --- SSL certs (local dev only) ---
cert.pem
key.pem
mkcert.exe
*.pem

# --- Editor ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# --- Temp / Build ---
*.tmp
*.temp
.cache/
build/

# --- OS ---
Desktop.ini
